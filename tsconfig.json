{
  "compilerOptions": {
    "incremental": true,
    "target": "es2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"], // TS6 default is [] (no auto-discovery); explicit now so upgrade is a no-op
    "rootDir": "./src", // TS6 requires rootDir to match the common source directory
    "lib": ["dom", "es2022"],
    "jsx": "react-jsx",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": ".erb/dll"
  },
  "exclude": ["test", "release/build", "release/app/dist", ".erb/dll", ".erb/configs"]
}
